# Flask
FLASK_SECRET_KEY=change-this-to-a-long-random-string
FLASK_DEBUG=False

# Database (Postgres)
DB_USER=gamepodra
DB_PASSWORD=change-this-too
DB_NAME=gamepodra
DATABASE_URL=postgresql://gamepodra:change-this-too@db:5432/gamepodra

# Razorpay
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Rate limiting (redis://redis:6379/0 for multi-worker via compose, memory:// for dev)
RATE_LIMIT_STORAGE=redis://redis:6379/0

# Port mapping (Docker only)
APP_PORT=8080

# Discord Bot
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=123456789
DISCORD_ANNOUNCEMENT_CHANNEL_ID=123456789
SERVER_IP=play.yourserver.com

# Role IDs (Discord)
ROLE_ID_DEFAULT=0
ROLE_ID_NEW_MEMBER=0
ROLE_ID_OG_MEMBER=0
ROLE_ID_IRON=0
ROLE_ID_GOLD=0
ROLE_ID_DIAMOND=0
ROLE_ID_NETHER=0
ROLE_ID_GOD=0

# Role thresholds (days)
NEW_MEMBER_DAYS=30
OG_MEMBER_DAYS=365
