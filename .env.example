# =============================================================
#  GAMEPODRA — unified environment file
#  Copy to .env at project root and fill in real values.
#  Both the Flask web app and the Discord bot read from here.
# =============================================================


# ── Flask ─────────────────────────────────────────────────────
FLASK_SECRET_KEY=change-this-to-a-long-random-string
FLASK_DEBUG=False


# ── Database ──────────────────────────────────────────────────
# Used by Flask (ORM) and the Discord bot (SQLAlchemy Core).
# Must point at the same DB instance.
DB_USER=gamepodra
DB_PASSWORD=change-this-too
DB_NAME=gamepodra
DATABASE_URL=postgresql://gamepodra:change-this-too@db:5432/gamepodra
# MySQL/MariaDB alternative (comment out the postgres line above):
# DATABASE_URL=mysql+pymysql://gamepodra:change-this-too@db:3306/gamepodra


# ── Razorpay ──────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret


# ── Rate limiting ─────────────────────────────────────────────
# redis://redis:6379/0  →  multi-worker production (Docker Compose)
# memory://             →  single-process local dev
RATE_LIMIT_STORAGE=redis://redis:6379/0


# ── Ports (Docker only) ───────────────────────────────────────
APP_PORT=8080


# ── Discord bot ───────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=123456789
DISCORD_ANNOUNCEMENT_CHANNEL_ID=123456789

# Minecraft server IPs shown by the /ip command and "ip" message trigger
JAVA_IP=play.yourserver.com
BEDROCK_IP=play.yourserver.com
BEDROCK_PORT=19132


# ── Discord role IDs ──────────────────────────────────────────
# Right-click a role in Discord → Copy Role ID (Developer Mode must be on).
# Leave as 0 to disable that role entirely.
ROLE_ID_DEFAULT=0
ROLE_ID_NEW_MEMBER=0
ROLE_ID_OG_MEMBER=0

# Rank roles — must match rank_key values in the payments table
ROLE_ID_IRON=0
ROLE_ID_GOLD=0
ROLE_ID_DIAMOND=0
ROLE_ID_NETHER=0
ROLE_ID_GOD=0


# ── Membership thresholds (days since joining the Discord server) ──
NEW_MEMBER_DAYS=1
OG_MEMBER_DAYS=365
